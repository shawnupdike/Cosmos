generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Planet {
  id        Int        @id @default(autoincrement())
  name      String
  resources Resource[]
}

model Resource {
  id        Int     @id @default(autoincrement())
  name      String
  price     Float
  change    Float
  planetId  Int
  planet    Planet  @relation(fields: [planetId], references: [id])
}